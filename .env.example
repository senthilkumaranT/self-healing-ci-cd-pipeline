# GitHub Personal Access Token (PAT) with "actions:read" (and "repo" if private repository) scope.
# This token is used by the FastAPI backend to fetch logs from the GitHub Actions REST API.
GITHUB_TOKEN=your_github_personal_access_token_here

# Webhook Authentication Secret
WEBHOOK_SECRET=your_webhook_secret_here

# Groq API Key for LLM Analysis
GROQ_API_KEY=your_groq_api_key_here
